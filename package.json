{
  "name": "gdi-hero-animation",
  "version": "1.0.0",
  "description": "Production-ready cinematic hero animation for GDI FutureWorks AI webinar landing page",
  "type": "module",
  "scripts": {
    "dev": "remotion preview src/index.tsx",
    "build": "remotion render src/index.tsx HeroAnimation out/hero.mp4",
    "build:mobile": "remotion render src/index.tsx HeroAnimation_Mobile out/hero-mobile.mp4",
    "build:preview": "remotion render src/index.tsx HeroAnimation_Preview out/hero-preview.mp4",
    "build:all": "npm run build && npm run build:mobile && npm run build:preview",
    "test": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src",
    "serve": "remotion preview src/index.tsx --port 3000"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "@remotion/three": "^4.0.0",
    "three": "^0.158.0",
    "@react-three/fiber": "^8.16.0",
    "@react-three/drei": "^9.100.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.158.0",
    "@types/node": "^20.8.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "prettier": "^3.0.3",
    "vite": "^4.5.0",
    "@vitejs/plugin-react": "^4.1.0",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
